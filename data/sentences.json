{
  "lessons": [
    {
      "id": "lesson-01",
      "title": "Ordering a Coffee",
      "titleZh": "点咖啡",
      "sentences": [
        {
          "id": "l01-s01",
          "en": "Could I get a flat white to take away, please?",
          "zh": "我可以要一杯外带的澄白咖啡吗？",
          "audio": "audio/l01-s01.webm",
          "words": [
            "flat white",
            "take away"
          ]
        },
        {
          "id": "l01-s02",
          "en": "Sorry, do you have any oat milk?",
          "zh": "不好意思，请问有燕麦奶吗？",
          "audio": "audio/l01-s02.webm",
          "words": [
            "oat milk"
          ]
        },
        {
          "id": "l01-s03",
          "en": "That's grand, thanks very much.",
          "zh": "太好了，非常感谢。",
          "audio": "audio/l01-s03.webm",
          "words": [
            "grand"
          ]
        },
        {
          "id": "l01-s04",
          "en": "Hi there, what can I get for you today?",
          "zh": "你好，今天想喝点什么？",
          "audio": "audio/l01-s04.webm",
          "words": [
            "what can i get for you"
          ]
        },
        {
          "id": "l01-s05",
          "en": "What sizes do you do?",
          "zh": "你们有哪些杯型？",
          "audio": "audio/l01-s05.webm",
          "words": [
            "sizes"
          ]
        },
        {
          "id": "l01-s06",
          "en": "I'll have a medium latte, please.",
          "zh": "我要一杯中杯拿铁，谢谢",
          "audio": "audio/l01-s06.webm",
          "words": [
            "medium"
          ]
        },
        {
          "id": "l01-s07",
          "en": "Could I get it decaf, please?",
          "zh": "可以帮我做成低咖啡因的吗？",
          "audio": "audio/l01-s07.webm",
          "words": [
            "decaf"
          ]
        },
        {
          "id": "l01-s08",
          "en": "Could I get an extra shot of espresso?",
          "zh": "可以加一份浓缩咖啡吗？",
          "audio": "audio/l01-s08.webm",
          "words": [
            "extra shot"
          ]
        },
        {
          "id": "l01-s09",
          "en": "No sugar for me, thanks.",
          "zh": "我不要加糖，谢谢。",
          "audio": "audio/l01-s09.webm",
          "words": [
            "no sugar"
          ]
        },
        {
          "id": "l01-s10",
          "en": "Do you do almond milk as well?",
          "zh": "你们也有杏仁奶吗？",
          "audio": "audio/l01-s10.webm",
          "words": [
            "almond milk"
          ]
        },
        {
          "id": "l01-s11",
          "en": "Sorry, I'm actually allergic to nuts — is that safe?",
          "zh": "不好意思，我对坚果过敏——这个安全吗？",
          "audio": "audio/l01-s11.webm",
          "words": [
            "allergic"
          ]
        },
        {
          "id": "l01-s12",
          "en": "Could I also grab a slice of carrot cake?",
          "zh": "我可以再要一块胡萝卜蛋糕吗？",
          "audio": "audio/l01-s12.webm",
          "words": [
            "grab"
          ]
        },
        {
          "id": "l01-s13",
          "en": "Is that for here or to go?",
          "zh": "是在这里用还是带走？",
          "audio": "audio/l01-s13.webm",
          "words": [
            "for here"
          ]
        },
        {
          "id": "l01-s14",
          "en": "To go, please.",
          "zh": "带走，谢谢。",
          "audio": "audio/l01-s14.webm",
          "words": [
            "to go"
          ]
        }
      ]
    },
    {
      "id": "lesson-02",
      "title": "Asking for Directions",
      "titleZh": "问路",
      "sentences": [
        {
          "id": "l02-s01",
          "en": "Excuse me, is this the right way to the station?",
          "zh": "打扰一下，请问这条路是去车站的吗？",
          "audio": "audio/l02-s01.webm",
          "words": [
            "excuse me",
            "station"
          ]
        },
        {
          "id": "l02-s02",
          "en": "It's just round the corner, you can't miss it.",
          "zh": "就在拐角处，你一定能找到。",
          "audio": "audio/l02-s02.webm",
          "words": [
            "round the corner",
            "you can't miss it"
          ]
        }
      ]
    },
    {
      "id": "lesson-03",
      "title": "Settling into Halls",
      "titleZh": "入住宿舍",
      "sentences": [
        {
          "id": "l03-s01",
          "en": "Hiya, are you one of my new flatmates?",
          "zh": "嗨，你是我的新室友吗？",
          "audio": "audio/l03-s01.webm",
          "words": [
            "hiya",
            "flatmate"
          ]
        },
        {
          "id": "l03-s02",
          "en": "The kitchen's a bit of a state, sorry about that.",
          "zh": "厨房有点乱，不好意思。",
          "audio": "audio/l03-s02.webm",
          "words": [
            "a bit of a state"
          ]
        }
      ]
    }
